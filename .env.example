# GitHub OAuth App credentials (set as Cloudflare Worker secrets)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Repo info
GITHUB_REPO_OWNER=Chelebii
GITHUB_REPO_NAME=chelebi.dev

# Only this GitHub username can log in
ALLOWED_GITHUB_USERNAME=Chelebii

# Worker / client wiring
# Deploy workers/auth.js and expose its public URL to the admin page.
# Set in admin HTML or hosting runtime:
#   window.CMS_GITHUB_CLIENT_ID = "your_client_id"
#   window.CMS_OAUTH_EXCHANGE_URL = "https://your-worker-domain/auth/github"
